/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: blob: https://drive.google.com https://lh3.googleusercontent.com; connect-src https://script.google.com https://script.googleusercontent.com https://cotizador-worker.1328copias.workers.dev; worker-src blob:; frame-ancestors 'none'

/*.html
  Cache-Control: no-cache, no-store, must-revalidate

/styles.css
  Cache-Control: public, max-age=86400

/app.js
  Cache-Control: public, max-age=86400

/reset-password.js
  Cache-Control: public, max-age=86400

/set-password.js
  Cache-Control: public, max-age=86400

/cotizador.css
  Cache-Control: public, max-age=86400

/cotizador.js
  Cache-Control: public, max-age=86400

/cotizador-precios.json
  Cache-Control: no-cache

/assets/*
  Cache-Control: public, max-age=31536000, immutable
